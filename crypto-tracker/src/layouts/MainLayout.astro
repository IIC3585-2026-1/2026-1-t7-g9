---
import "../styles/global.css";

const { title = "Crypto Tracker" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="bg-slate-950 text-white min-h-screen">
    <slot />
  </body>
</html>